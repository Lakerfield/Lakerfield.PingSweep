<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Lakerfield.PingSweep</RootNamespace>

    <Authors>Michael Lakerveld</Authors>
    <Company>Lakerfield B.V.</Company>
    <Product>Lakerfield ping sweep</Product>
    <Copyright>Lakerfield B.V.</Copyright>
    <Description>A network ping sweep tool with interactive TUI and CLI modes.</Description>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>ping-sweep</ToolCommandName>
    <PackageId>Lakerfield.PingSweep</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" Version="0.55.2" />
  </ItemGroup>

</Project>
